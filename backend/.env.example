# Backend Port (Railway will automatically provide a PORT variable in production)
PORT=5000

# MongoDB Connection String
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/ai-fitness?retryWrites=true&w=majority

# JWT Secret for authentication
JWT_SECRET=your_super_secret_jwt_key_here

# OpenAI API Key for the AI Coach feature
OPENAI_API_KEY=sk-your_openai_api_key_here

# The URL of your deployed Vercel frontend (important for CORS security)
# Example: https://ai-fitness-coach.vercel.app
FRONTEND_URL=http://localhost:5173
